# MIRAGE Next.js Dashboard — Production Dockerfile
#
# Multi-stage build:
#   Stage 1: Install deps + build the Next.js standalone output
#   Stage 2: Slim runtime with only the standalone server + static files
#
# Usage:
#   docker build -f Dockerfile.web -t mirage-web:latest .
#   docker run --rm -p 3000:3000 \
#     -e NEXT_PUBLIC_SUPABASE_URL=... \
#     -e NEXT_PUBLIC_SUPABASE_ANON_KEY=... \
#     mirage-web:latest

# ---------- Stage 1: Builder ----------
FROM node:22-slim AS builder

# Install bun (used by the project)
RUN npm install -g bun@1.1.0

WORKDIR /build

# Copy lockfile + package.json first (cache deps)
COPY package.json bun.lock ./

# Install deps
RUN bun install --frozen-lockfile

# Copy source
COPY . .

# Build with standalone output (next.config.ts must have output: 'standalone')
RUN bun run build

# ---------- Stage 2: Runtime ----------
FROM node:22-slim AS runtime

WORKDIR /app

# Copy standalone server output
COPY --from=builder /build/.next/standalone ./
COPY --from=builder /build/.next/static ./.next/static
COPY --from=builder /build/public ./public

# Create non-root user
RUN useradd --create-home --uid 1000 mirage && chown -R mirage:mirage /app
USER mirage

EXPOSE 3000

# Healthcheck
HEALTHCHECK --interval=30s --timeout=3s --start-period=15s --retries=3 \
    CMD node -e "fetch('http://localhost:3000/').then(r=>process.exit(r.ok?0:1)).catch(()=>process.exit(1))"

# Next.js standalone server
ENV NODE_ENV=production
ENV HOSTNAME=0.0.0.0
ENV PORT=3000

CMD ["node", "server.js"]
